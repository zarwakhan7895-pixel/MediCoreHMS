@model IEnumerable<WebApplication1.Models.Patient>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Patients</h2>
<p>@Html.ActionLink("+ Add New Patient", "Create", null, new { @class = "btn btn-success mb-2" })</p>

@using (Html.BeginForm("Index", "Patients", FormMethod.Get))
{
    <input type="text" name="search" placeholder="Search by name or contact..." class="form-control mb-2" style="max-width:300px;display:inline-block;" />
    <button type="submit" class="btn btn-secondary mb-2">Search</button>
}

<table class="table table-striped">
    <tr>
        <th>Name</th><th>Age</th><th>Gender</th><th>Contact</th><th>Registered On</th><th></th>
    </tr>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.FullName</td>
            <td>@p.Age</td>
            <td>@p.Gender</td>
            <td>@p.ContactNumber</td>
            <td>@p.RegisteredOn.ToShortDateString()</td>
            <td>
                @Html.ActionLink("Details", "Details", new { id = p.PatientId }, new { @class = "btn btn-sm btn-info" })
                @Html.ActionLink("Edit", "Edit", new { id = p.PatientId }, new { @class = "btn btn-sm btn-warning" })
                @Html.ActionLink("Delete", "Delete", new { id = p.PatientId }, new { @class = "btn btn-sm btn-danger" })
            </td>
        </tr>
    }
</table>
