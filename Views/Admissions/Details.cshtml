@model WebApplication1.Models.Admission
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Admission Details</h2>
<dl class="row">
    <dt class="col-sm-3">Patient</dt><dd class="col-sm-9">@Model.Patient.FullName</dd>
    <dt class="col-sm-3">Doctor</dt><dd class="col-sm-9">@Model.Doctor.FullName</dd>
    <dt class="col-sm-3">Ward</dt><dd class="col-sm-9">@Model.Ward</dd>
    <dt class="col-sm-3">Bed</dt><dd class="col-sm-9">@Model.Bed.Ward - Bed #@Model.Bed.BedNumber</dd>
    <dt class="col-sm-3">Entry Type</dt><dd class="col-sm-9">@Model.EntryType</dd>
    <dt class="col-sm-3">Admission Date</dt><dd class="col-sm-9">@Model.AdmissionDate</dd>
    <dt class="col-sm-3">Discharge Date</dt><dd class="col-sm-9">@(Model.DischargeDate?.ToString("dd-MMM-yyyy") ?? "Not discharged yet")</dd>
    <dt class="col-sm-3">Treatment Summary</dt><dd class="col-sm-9">@Model.TreatmentSummary</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@(Model.IsDischarged ? "Discharged" : "Admitted")</dd>
</dl>
@Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
